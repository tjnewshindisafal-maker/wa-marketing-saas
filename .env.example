# ========================================
# WA Marketing SaaS - Environment Variables
# ========================================
# Copy this file to .env and fill real values
# NEVER commit .env to git!

# MongoDB connection (get from MongoDB Atlas)
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/wamarketing

# JWT Secret - must be random 64+ char string
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_RANDOM_96_CHAR_HEX_STRING

# Admin credentials
[email protected]
ADMIN_PASS=CHANGE_THIS_STRONG_PASSWORD

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com

# Allowed CORS origins (comma-separated, no spaces)
ALLOWED_ORIGINS=https://wadigit.com,https://wa-marketing-saas-1.onrender.com

# Server port (Render sets this automatically)
PORT=8080
